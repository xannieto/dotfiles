### Colours
#
default_floating_border none
default_border normal
hide_edge_borders smart

# colours
set $bg-color				#2e3440
set $inactive-bg-color   	#d8dee9
set $text-color          	#eceff4
set $inactive-text-color 	#4c566a
set $urgent-bg-color     	#b48ead
#
#                       border              background         text                 indicator
client.focused          $bg-color           $bg-color          $text-color          #ff00ff
client.unfocused        $inactive-bg-color  $inactive-bg-color $inactive-text-color #ff00ff
client.focused_inactive $inactive-bg-color  $inactive-bg-color $inactive-text-color #ff00ff
client.urgent           $urgent-bg-color    $urgent-bg-color   $text-color          #ff00ff

bindsym $mod+p       exec shotman active
bindsym $mod+Shift+p exec shotman area
bindsym $mod+Alt+p  exec shotman output
bindsym $mod+Ctrl+p  exec shotman window

for_window [title="shotman"] move position 30 30, floating enable
title_align left

exec --no-startup-id gammastep -c ~/.config/gammastep/gammastep.conf

exec --no-startup-id ulauncher

set $gnome-schema org.gnome.desktop.interface

exec_always {
    gsettings set $gnome-schema gtk-theme 'Adwaita-dark'
    gsettings set $gnome-schema icon-theme 'Newaita-dark'
    gsettings set $gnome-schema cursor-theme 'Adwaita'
    gsettings set $gnome-schema font-name 'Roboto 12'
    gsettings set org.gnome.desktop.wm.preferences button-layout ''
}

include /etc/sway/config.d/*

